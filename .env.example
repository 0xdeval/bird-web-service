# Bird API Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# X Account Credentials
# Extract these from x.com (see SETUP.md for instructions)
AUTH_TOKEN=your_x_auth_token_cookie_here
CT0=your_x_ct0_cookie_here

# API Security
# Use a random, long string to protect your Bird API instance
API_SECRET=your_super_secret_api_key_here_change_me

# Server Configuration
PORT=3000
NODE_ENV=production

# Optional: Advanced Configuration
# TIMEOUT=30000          # Request timeout in milliseconds
# LOG_LEVEL=info         # Logging level (debug, info, warn, error)
